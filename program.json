{
  "meta": {
    "name": "Ipertrofia 3 Mesi — Fullbody",
    "userName": "Lorenz",
    "description": "Programma ipertrofia evidence-based, 3 mesi, 3x settimana fullbody. Fonti: Schoenfeld 2017, Robinson 2024, Pelland 2024, Israetel RP Strength.",
    "version": "1.0",
    "weeks": 12,
    "sessionsPerWeek": 3,
    "sequence": ["A", "B", "C"],
    "weekAdvanceAfter": "C",
    "notes": "Niente squat/affondi (crociato subtotale). Manubri su spinta (spalla destra). Pressa pendulum come esercizio principale gambe."
  },

  "phases": [
    {
      "name": "Accumulo",
      "label": "Fase 1 — Accumulo",
      "weeks": [1, 2, 3, 4],
      "rpe": "RPE 7-8",
      "rirNote": "RIR 2-1",
      "description": "Volume base, tecnica, adattamento. Partire conservativi sui carichi."
    },
    {
      "name": "Intensificazione",
      "label": "Fase 2 — Intensificazione",
      "weeks": [5, 6, 7, 8],
      "rpe": "RPE 8-9",
      "rirNote": "RIR 1-0",
      "description": "Carichi crescenti, rep scendono. Spingere progressivamente."
    },
    {
      "name": "Deload",
      "label": "Deload",
      "weeks": [9],
      "rpe": "RPE 5-6",
      "rirNote": "RIR 3-4",
      "description": "Scarico attivo. Carico -30%, volume -50%. Non saltare."
    },
    {
      "name": "Peak Estivo",
      "label": "Fase 3 — Peak Estivo",
      "weeks": [10, 11, 12],
      "rpe": "RPE 8-9",
      "rirNote": "RIR 1-0",
      "description": "Massimo output. Carichi peak, volume moderato."
    }
  ],

  "weekNotes": {
    "1":  "Accumulo W1 · Tecnica + adattamento · RIR 2",
    "2":  "Accumulo W2 · +carico se tutte le reps ok · RIR 2",
    "3":  "Accumulo W3 · Volume sale · RIR 1-2",
    "4":  "Accumulo W4 · Settimana più dura del blocco · RIR 1",
    "5":  "Intensificazione W5 · Carichi più alti, rep scendono · RIR 2",
    "6":  "Intensificazione W6 · Spingi i carichi · RIR 1-2",
    "7":  "Intensificazione W7 · Volume massimo del blocco · RIR 1",
    "8":  "Intensificazione W8 · Settimana più dura · RIR 0-1",
    "9":  "Deload · Carico -30%, volume -50% · RIR 3-4",
    "10": "Peak W10 · Riprendi i carichi · RIR 2",
    "11": "Peak W11 · Spinta finale · RIR 1",
    "12": "Peak W12 · Massimo output · RIR 0-1"
  },

  "volumeScheme": {
    "compound": {
      "sets":    { "w1": 2, "w2": 2, "w3": 3, "w4": 3, "w5": 3, "w6": 3, "w7": 4, "w8": 4, "w9": 2, "w10": 3, "w11": 3, "w12": 4 },
      "reps":    { "acc": "10-12", "int": "8-10", "del": "12-15", "peak": "6-8" },
      "rest":    { "acc": "2 min", "int": "2 min", "del": "90s",   "peak": "2.5 min" }
    },
    "isolation": {
      "sets":    { "w1": 2, "w2": 2, "w3": 2, "w4": 2, "w5": 3, "w6": 3, "w7": 3, "w8": 3, "w9": 2, "w10": 3, "w11": 3, "w12": 3 },
      "reps":    { "acc": "12-15", "int": "10-12", "del": "15-20", "peak": "10-12" },
      "rest":    { "acc": "90s",   "int": "90s",    "del": "60s",   "peak": "90s" }
    },
    "postural": {
      "sets":    { "w1": 2, "w2": 2, "w3": 2, "w4": 2, "w5": 2, "w6": 2, "w7": 2, "w8": 2, "w9": 2, "w10": 2, "w11": 2, "w12": 2 },
      "reps":    { "acc": "15-20", "int": "15-20", "del": "15-20", "peak": "15-20" },
      "rest":    { "acc": "60s",   "int": "60s",    "del": "60s",   "peak": "60s" }
    },
    "calf": {
      "sets":    { "w1": 2, "w2": 2, "w3": 3, "w4": 3, "w5": 3, "w6": 3, "w7": 4, "w8": 4, "w9": 2, "w10": 3, "w11": 3, "w12": 4 },
      "reps":    { "acc": "15-20", "int": "12-15", "del": "20-25", "peak": "12-15" },
      "rest":    { "acc": "60s",   "int": "60s",    "del": "60s",   "peak": "60s" }
    }
  },

  "workouts": {
    "A": {
      "name": "Allenamento A",
      "meta": "Spinta · Quadricipiti · Braccia",
      "color": "#e8ff3c",
      "exercises": [
        {
          "id": "A1",
          "name": "Pressa Pendulum",
          "muscle": "Quadricipiti / Glutei",
          "type": "compound",
          "warmup": true,
          "method": "buffer",
          "methodLabel": "Buffer RIR",
          "note": "Warm-up 1×15 leggero. Piedi medi, schiena incollata. Stop prima del cedimento. ⚠ ginocchio controllato.",
          "refKg": {
            "acc":  "~155kg",
            "int":  "~165-170kg",
            "del":  "~120kg",
            "peak": "~180kg"
          }
        },
        {
          "id": "A2",
          "name": "Panca Piana Manubri",
          "muscle": "Petto / Tricipiti / Deltoidi ant.",
          "type": "compound",
          "warmup": true,
          "method": "buffer",
          "methodLabel": "Buffer RIR",
          "note": "Traiettoria libera, rispetta la spalla. RIR 2 prime serie → RIR 1 ultima.",
          "refKg": {
            "acc":  "~24-26kg cad.",
            "int":  "~26-28kg cad.",
            "del":  "~20kg cad.",
            "peak": "~28-30kg cad."
          }
        },
        {
          "id": "A3",
          "name": "Alzate Laterali Cavi (basso)",
          "muscle": "Deltoidi laterali",
          "type": "isolation",
          "warmup": false,
          "method": "cedimento",
          "methodLabel": "Cedimento",
          "note": "Cavo basso → tensione costante lungo tutto il range. Ultima serie al cedimento.",
          "refKg": {
            "acc":  "~6-8kg",
            "int":  "~8-10kg",
            "del":  "~5kg",
            "peak": "~8-10kg"
          }
        },
        {
          "id": "A4",
          "name": "Curl Manubri (alternato)",
          "muscle": "Bicipiti / Brachiale",
          "type": "isolation",
          "warmup": false,
          "method": "cedimento",
          "methodLabel": "Cedimento",
          "note": "Supinazione completa in cima. Ultima serie al cedimento, no slancio.",
          "refKg": {
            "acc":  "~12-14kg cad.",
            "int":  "~14-16kg cad.",
            "del":  "~10kg cad.",
            "peak": "~14-16kg cad."
          }
        },
        {
          "id": "A5",
          "name": "Calf Raise (leg press o macchina)",
          "muscle": "Gastrocnemio / Soleo",
          "type": "calf",
          "warmup": false,
          "method": "cedimento",
          "methodLabel": "Cedimento",
          "note": "Range completo, pausa 1s in basso. Cedimento ultima serie. Se al leg press usa il bordo della piattaforma.",
          "refKg": {
            "acc":  "~60-70kg (leg press) / ~30kg macchina",
            "int":  "~70-80kg / ~35kg",
            "del":  "~50kg / ~25kg",
            "peak": "~80kg / ~40kg"
          }
        }
      ]
    },

    "B": {
      "name": "Allenamento B",
      "meta": "Tirata · Femorali · Spalle",
      "color": "#3cffb4",
      "exercises": [
        {
          "id": "B1",
          "name": "Stacco Rumeno Bilanciere",
          "muscle": "Femorali / Glutei / Erettori",
          "type": "compound",
          "warmup": true,
          "method": "buffer",
          "methodLabel": "Buffer RIR",
          "note": "Warm-up: 1×10 a vuoto + 1×8 leggero. Bilanciere vicino alle gambe, stop a metà tibia.",
          "refKg": {
            "acc":  "~70kg",
            "int":  "~74-76kg",
            "del":  "~55kg",
            "peak": "~80kg"
          }
        },
        {
          "id": "B2",
          "name": "Rematore Manubrio (unilaterale)",
          "muscle": "Dorsali / Romboidi / Bicipiti",
          "type": "compound",
          "warmup": true,
          "method": "buffer",
          "methodLabel": "Buffer RIR",
          "note": "Appoggio su panca, schiena parallela. Gomito vicino al corpo, tira verso l'anca.",
          "refKg": {
            "acc":  "~24-26kg cad.",
            "int":  "~26-28kg cad.",
            "del":  "~20kg cad.",
            "peak": "~28-30kg cad."
          }
        },
        {
          "id": "B3",
          "name": "Fly Pec Machine (reverse grip)",
          "muscle": "Petto medio / Petto basso",
          "type": "isolation",
          "warmup": false,
          "method": "cedimento",
          "methodLabel": "Cedimento",
          "note": "Tensione costante, non bloccare i gomiti. Ultima serie al cedimento.",
          "refKg": {
            "acc":  "~30-35kg",
            "int":  "~35-40kg",
            "del":  "~25kg",
            "peak": "~40-45kg"
          }
        },
        {
          "id": "B4",
          "name": "Facepull Cavi (corda)",
          "muscle": "Deltoidi post. / Trapezi / Rotatori",
          "type": "postural",
          "warmup": false,
          "method": "buffer",
          "methodLabel": "Buffer RIR",
          "note": "⚑ POSTURALE — non skippare mai. Cavo altezza viso, gomiti alti, apertura esterna.",
          "refKg": {
            "acc":  "~12-15kg",
            "int":  "~12-15kg",
            "del":  "~10kg",
            "peak": "~12-15kg"
          }
        },
        {
          "id": "B5",
          "name": "Reverse Fly Pec Deck",
          "muscle": "Deltoidi posteriori / Romboidi",
          "type": "isolation",
          "warmup": false,
          "method": "cedimento",
          "methodLabel": "Cedimento",
          "note": "Seduto al contrario sulla pec deck. Gomiti leggermente flessi, apertura controllata. Ultima serie al cedimento.",
          "refKg": {
            "acc":  "~15-20kg",
            "int":  "~20-25kg",
            "del":  "~12kg",
            "peak": "~25kg"
          }
        }
      ]
    },

    "C": {
      "name": "Allenamento C",
      "meta": "Fullbody composito",
      "color": "#ff6b3c",
      "exercises": [
        {
          "id": "C1",
          "name": "Bulgarian Split Squat",
          "muscle": "Quadricipiti / Glutei / Femorali",
          "type": "compound",
          "warmup": true,
          "method": "buffer",
          "methodLabel": "Buffer RIR",
          "note": "⚠ Monitorare ginocchio. Warm-up con solo peso corpo. Piede posteriore su panca, busto eretto. Parti leggero W1-2. Se fastidio → sostituire con pressa piedi alti.",
          "refKg": {
            "acc":  "solo peso corpo W1-2, poi ~10kg cad.",
            "int":  "~14-16kg cad.",
            "del":  "solo peso corpo",
            "peak": "~18-20kg cad."
          }
        },
        {
          "id": "C2",
          "name": "Panca Inclinata Manubri (30°)",
          "muscle": "Petto alto / Deltoidi ant.",
          "type": "compound",
          "warmup": false,
          "method": "buffer",
          "methodLabel": "Buffer RIR",
          "note": "30° max — oltre si sposta sulle spalle. Manubri, traiettoria libera.",
          "refKg": {
            "acc":  "~20-22kg cad.",
            "int":  "~22-24kg cad.",
            "del":  "~16kg cad.",
            "peak": "~24-26kg cad."
          }
        },
        {
          "id": "C3",
          "name": "Trazioni (presa prona)",
          "muscle": "Dorsali / Bicipiti / Romboidi",
          "type": "compound",
          "warmup": false,
          "method": "buffer",
          "methodLabel": "Buffer RIR",
          "note": "Se meno di 6 reps pulite → lat machine. Presa prona larghezza spalle, scapole verso il basso.",
          "refKg": {
            "acc":  "peso corpo (o lat machine ~55-60kg)",
            "int":  "peso corpo + zavorra / ~60-65kg",
            "del":  "peso corpo leggero / ~50kg",
            "peak": "peso corpo + zavorra / ~65kg"
          }
        },
        {
          "id": "C4",
          "name": "Shoulder Press Macchina",
          "muscle": "Deltoidi / Trapezi superiori",
          "type": "compound",
          "warmup": false,
          "method": "buffer",
          "methodLabel": "Buffer RIR",
          "note": "Macchina guidata: sicura per la spalla. Seduta dritta, no iperestensione lombare.",
          "refKg": {
            "acc":  "~30-35kg",
            "int":  "~33-38kg",
            "del":  "~25kg",
            "peak": "~38-42kg"
          }
        },
        {
          "id": "C5",
          "name": "Hammer Curl Manubri",
          "muscle": "Bicipiti / Brachiale / Brachioradiale",
          "type": "isolation",
          "warmup": false,
          "method": "cedimento",
          "methodLabel": "Cedimento",
          "note": "Presa neutra (martello). Colpisce brachiale → spessore braccio. Ultima serie al cedimento.",
          "refKg": {
            "acc":  "~12-14kg cad.",
            "int":  "~14-16kg cad.",
            "del":  "~10kg cad.",
            "peak": "~14-16kg cad."
          }
        },
        {
          "id": "C6",
          "name": "Pushdown Tricipiti Cavi (corda)",
          "muscle": "Tricipiti (isolamento)",
          "type": "isolation",
          "warmup": false,
          "method": "cedimento",
          "methodLabel": "Cedimento",
          "note": "Gomiti fissi ai fianchi. Apertura corda in basso, estensione completa.",
          "refKg": {
            "acc":  "~15-18kg",
            "int":  "~18-20kg",
            "del":  "~12kg",
            "peak": "~20-22kg"
          }
        }
      ]
    }
  }
}
